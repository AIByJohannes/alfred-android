<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Constrain the butler suit PNG to the 72dp adaptive icon safe zone,
         centered within the 108dp adaptive icon canvas (18dp bleed on each side). -->
    <item
        android:width="72dp"
        android:height="72dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/ic_launcher_foreground_png"
            android:gravity="fill" />
    </item>
</layer-list>
