<resources>
    <!-- Base application theme. -->
    <style name="Theme.Alfred" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/palette_blue</item>
        <item name="colorPrimaryVariant">@color/palette_blue</item>
        <item name="colorOnPrimary">@color/palette_white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/palette_cyan</item>
        <item name="colorSecondaryVariant">@color/palette_cyan</item>
        <item name="colorOnSecondary">@color/palette_white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:navigationBarColor">@color/palette_blue</item>
        <item name="android:windowBackground">@color/window_background</item>
        <item name="colorSurface">@color/palette_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="colorControlActivated">@color/palette_blue</item>
        <item name="colorAccent">@color/palette_blue</item>
        <!-- Exposed dropdown popup styling -->
        <item name="autoCompleteTextViewStyle">@style/Widget.Alfred.AutoCompleteTextView</item>
    </style>

    <style name="Theme.Alfred.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Alfred.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Alfred.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="Widget.Alfred.AutoCompleteTextView" parent="Widget.AppCompat.AutoCompleteTextView">
        <item name="android:popupBackground">@drawable/bg_dropdown_popup</item>
    </style>

    <style name="Theme.Alfred.BottomSheetDialog" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Alfred.BottomSheet</item>
    </style>

    <style name="Widget.Alfred.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
</resources>